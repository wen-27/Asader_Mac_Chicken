# Local runtime identity.
APP_NAME="ASADERO MC Bot Backend"
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.1.0

# FastAPI bind settings.
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Infrastructure endpoints. PostgreSQL is the source of truth; Redis and Chroma
# are disposable helpers that can be rebuilt from database/catalog data.
DATABASE_URL=postgresql+asyncpg://asadero_mc_user:asadero_local_2026@localhost:5432/asadero_mc_admin
BOT_DATABASE_SCHEMA=bot
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Local admin user seeded into PostgreSQL by scripts.seed.
ADMIN_EMAIL=admin@asadero.local
ADMIN_PASSWORD=servor1230
ADMIN_NAME=Administrador

# Telegram legacy/local webhook credentials. Fill only if you still test Telegram locally.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# WhatsApp Cloud API credentials. These are the production customer channel.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=change-this-whatsapp-verify-token
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_SEND_TIMEOUT_SECONDS=4.0
WHATSAPP_MENU_IMAGE_MEDIA_ID=

# Natural-language parsing. Gemini is used only after deterministic rules fail.
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash-lite
LLM_FALLBACK_ENABLED=true
GEMINI_TIMEOUT_SECONDS=3.0
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Delivery pricing fallback. Manual seeded delivery zones are evaluated first.
DELIVERY_ORIGIN_ADDRESS="Cra 3 # 48-06, Lagos II, Floridablanca, Santander, Colombia"
DELIVERY_BASE_PRICE_COP=2000
DELIVERY_PRICE_PER_KM_COP=1300
DELIVERY_ROUND_TO_COP=500
OPENROUTESERVICE_API_KEY=
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
BUSINESS_HOURS_ENFORCED=true
# Optional comma-separated YYYY-MM-DD overrides for special products.
# Colombian Monday public holidays are calculated automatically.
SPECIAL_PRODUCT_MONDAY_HOLIDAYS=

# Internal Node backend integration. The bot calls this after confirming orders,
# and the backend calls the bot to send admin messages to the customer.
ADMIN_BACKEND_BASE_URL=http://localhost:3000/api/v1/internal
INTERNAL_API_KEY=change-this-internal-api-key
ADMIN_BACKEND_SYNC_ENABLED=false
ADMIN_BACKEND_TIMEOUT_SECONDS=0.4

# Runtime logging.
LOG_LEVEL=INFO
